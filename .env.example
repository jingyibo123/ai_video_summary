# =================================================================
# AI Video Summary - Environment Variables
# =================================================================
# 复制此文件为 .env 并填入实际值。.env 已加入 .gitignore，不会入库。
# 变量名使用双下划线 (__) 分隔嵌套字段，由 pydantic-settings 自动映射。
# =================================================================

# -----------------------------------------------------------------
# VLM (Vision-Language Model) — 用于幻灯片 OCR、验证、去重、摘要
# -----------------------------------------------------------------
VLM__BASE_URL=http://localhost:1234/v1
VLM__MODEL=qwen2-vl-7b
VLM__API_KEY=none

# -----------------------------------------------------------------
# ASR (Automatic Speech Recognition) — Whisper 兼容 API（默认模式）
# 如需切换到本地 Faster-Whisper，将 ASR__API_BASE 注释掉或设为空，
# 并运行: uv sync --extra local-whisper
# -----------------------------------------------------------------
ASR__API_BASE=http://localhost:8000/v1
ASR__MODEL_SIZE=whisper-large-v3
ASR__API_KEY=none

# 仅本地模式使用：
# ASR__API_BASE=
# ASR__MODEL_SIZE=base
# ASR__LOCAL_DEVICE=cpu
# ASR__LOCAL_COMPUTE_TYPE=int8
